# Production environment — copy to .env and adjust values

# PostgreSQL (if not using managed DB)
POSTGRES_DB=memora
POSTGRES_USER=memora
POSTGRES_PASSWORD=change-me-strong-password

# Backend
JWT_SECRET=change-me-use-at-least-256-bits-for-hs256-in-production
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Frontend (build-time for Docker image)
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api
NEXT_PUBLIC_USE_MOCKS=false
